{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "TRUE"
      }
    },
    {
      "name": "asan",
      "inherits": "base",
      "displayName": "AddressSanitizer",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_SANITIZER_ADDRESS": "ON",
        "ENABLE_SANITIZER_LEAK": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "base",
      "displayName": "ThreadSanitizer",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_SANITIZER_THREAD": "ON"
      }
    },
    {
      "name": "ubsan",
      "inherits": "base",
      "displayName": "UBSanitizer",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_SANITIZER_UNDEFINED": "ON"
      }
    },
    {
      "name": "msan",
      "inherits": "base",
      "displayName": "MemorySanitizer (Clang only)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "ENABLE_SANITIZER_MEMORY": "ON"
      }
    },
    {
      "name": "coverage",
      "inherits": "base",
      "displayName": "Coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "clang-tidy",
      "inherits": "debug",
      "displayName": "Debug + clang-tidy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "cross-arm-linux",
      "inherits": "base",
      "displayName": "Cross: ARM Linux",
      "toolchainFile": "${sourceDir}/toolchain/arm-linux-gnueabihf.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "cross-arm-baremetal",
      "inherits": "base",
      "displayName": "Cross: ARM bare-metal",
      "toolchainFile": "${sourceDir}/toolchain/arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "pgo-generate",
      "inherits": "base",
      "displayName": "PGO: Generate profiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-fprofile-generate",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-generate"
      }
    },
    {
      "name": "pgo-use",
      "inherits": "base",
      "displayName": "PGO: Use profiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-fprofile-use -fprofile-correction",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-use"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",        "configurePreset": "debug" },
    { "name": "release",      "configurePreset": "release" },
    { "name": "asan",         "configurePreset": "asan" },
    { "name": "tsan",         "configurePreset": "tsan" },
    { "name": "ubsan",        "configurePreset": "ubsan" },
    { "name": "coverage",     "configurePreset": "coverage" },
    { "name": "pgo-generate", "configurePreset": "pgo-generate" },
    { "name": "pgo-use",      "configurePreset": "pgo-use" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": { "outputOnFailure": true }
    }
  ]
}
